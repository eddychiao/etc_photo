{
  "name": "photography-site",
  "version": "1.0.0",
  "description": "Personal photography website",
  "scripts": {
    "build": "tsc && tsc -p tsconfig.client.json",
    "build:client": "tsc -p tsconfig.client.json",
    "start": "node dist/server.js",
    "dev": "tsc -p tsconfig.client.json && ts-node src/server.ts",
    "export": "tsc -p tsconfig.client.json && ts-node scripts/export.ts"
  },
  "dependencies": {
    "express": "^4.18.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
