<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= collection.title %> — Eddy Chiao</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Inter:wght@300;400;500&family=Noto+Serif+SC:wght@300;400&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
  <link rel="icon" type="image/svg+xml" href="/photos/public/favicon_dark.svg">
</head>
<body class="inner-body">

  <%- include('partials/nav') %>

  <main class="photography-main">
    <div class="photography-header">
      <a href="/photography" class="collection-back">← Photography</a>
      <h1><%= collection.title %></h1>
      <div class="photography-header-rule"></div>
    </div>

    <%#
      Photos live in: public/photos/collections/[slug]/
      Add filenames to the photos array for this collection in src/server.ts
    %>
    <% if (collection.photos.length > 0) { %>
      <div class="photography-grid">
        <% collection.photos.forEach(filename => { %>
          <div class="photography-item">
            <div class="photography-img-wrap">
              <img
                src="/photos/collections/<%= collection.slug %>/<%= filename %>"
                alt=""
                loading="lazy"
                onerror="this.src='/photos/placeholder.svg'"
              >
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <p class="collection-empty">Photos coming soon.</p>
    <% } %>
  </main>

  <script src="/js/transitions.js"></script>
</body>
</html>
