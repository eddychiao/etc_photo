<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Photography — Eddy Chiao</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Inter:wght@300;400;500&family=Noto+Serif+SC:wght@300;400&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
  <link rel="icon" type="image/svg+xml" href="/photos/public/favicon_dark.svg">
</head>
<body class="inner-body">

  <%- include('partials/nav') %>

  <main class="photography-main">
    <div class="photography-header">
      <span class="section-cn">照片</span>
      <h1>Photography</h1>
      <div class="photography-header-rule"></div>
    </div>

    <div class="collection-grid">
      <% collections.forEach(col => { %>
        <a href="/photography/<%= col.slug %>" class="collection-panel">
          <div class="collection-cover">
            <img
              src="/photos/collections/<%= col.slug %>/<%= col.cover %>"
              alt="<%= col.title %>"
              loading="lazy"
              onerror="this.src='<%= basePath %>/photos/placeholder.svg'"
            >
          </div>
          <div class="collection-label">
            <span class="collection-title"><%= col.title %></span>
          </div>
        </a>
      <% }) %>
    </div>
  </main>

  <script src="/js/transitions.js"></script>
</body>
</html>
